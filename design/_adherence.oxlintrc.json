{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brain/**",
              "components/brand/**",
              "components/core/**",
              "components/discovery/**",
              "ui_kits/pwa/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Bricolage Grotesque|Geist|Geist Mono|Newsreader))/i]",
        "message": "Font not provided by the design system. Available: Bricolage Grotesque, Geist, Geist Mono, Newsreader."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|dot|className|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, dot, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomSheet'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|onGrip|height|children|className|key|ref|className|style|children)$/]",
        "message": "<BottomSheet> doesn't accept that prop. Declared props: state, onGrip, height, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrainCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|message|sub|thinking|actions|icon|className|key|ref|className|style|children)$/]",
        "message": "<BrainCard> doesn't accept that prop. Declared props: eyebrow, message, sub, thinking, actions, icon, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|loading|iconLeft|iconRight|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, loading, iconLeft, iconRight."
      },
      {
        "selector": "JSXOpeningElement[name.name='CajuPoints'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|delta|unit|size|chip|className|key|ref|className|style|children)$/]",
        "message": "<CajuPoints> doesn't accept that prop. Declared props: value, delta, unit, size, chip, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:from|children|thinking|className|key|ref|className|style|children)$/]",
        "message": "<ChatBubble> doesn't accept that prop. Declared props: from, children, thinking, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute[name.name='from'] > Literal[value!=/^(?:brain|user)$/]",
        "message": "<ChatBubble> from must be one of 'brain' | 'user'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|selected|brand|icon|as|onClick|className|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, selected, brand, icon, as, onClick, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|span)$/]",
        "message": "<Chip> as must be one of 'button' | 'span'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|variant|size|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, label, variant, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapPin'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|label|selected|dotOnly|onClick|className|key|ref|className|style|children)$/]",
        "message": "<MapPin> doesn't accept that prop. Declared props: type, label, selected, dotOnly, onClick, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='PromptBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|onSend|onVoice|placeholder|showMark|className|key|ref|className|style|children)$/]",
        "message": "<PromptBar> doesn't accept that prop. Declared props: value, onChange, onSend, onVoice, placeholder, showMark, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='RestaurantCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|cuisine|neighborhood|price|why|image|tags|badge|trust|saved|onSave|onClick|compact|className|key|ref|className|style|children)$/]",
        "message": "<RestaurantCard> doesn't accept that prop. Declared props: name, cuisine, neighborhood, price, why, image, tags, badge, trust, saved, onSave, onClick, compact, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='SourceChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|kind|weight|avatar|className|key|ref|className|style|children)$/]",
        "message": "<SourceChip> doesn't accept that prop. Declared props: name, kind, weight, avatar, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrustMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|label|pill|className|key|ref|className|style|children)$/]",
        "message": "<TrustMeter> doesn't accept that prop. Declared props: level, label, pill, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|tone|accent|as|className|key|ref|className|style|children)$/]",
        "message": "<Wordmark> doesn't accept that prop. Declared props: size, tone, accent, as, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:span|div)$/]",
        "message": "<Wordmark> as must be one of 'span' | 'div'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
