ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
PORT=8787
# SPEC-018 Admin CMS: shared secret operators send as X-Caju-Operator-Token. Unset disables /api/admin/* entirely.
# In production, this MUST be a real random secret — never the local dev default.
ADMIN_TOKEN=
# SPEC-016 Notifications: generate with `node -e "console.log(require('web-push').generateVAPIDKeys())"`.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@cajueat.local
# Where the JSON-persisted stores read/write. Leave unset for local dev (defaults to
# brain/data/). In production (Railway), set this to the mount path of a real Volume —
# the build output filesystem isn't persistent across deploys.
DATA_DIR=
# Restricts CORS to a single origin (the deployed PWA's real URL, e.g. https://cajueat.vercel.app).
# Leave unset for local dev — defaults to allowing any origin.
ALLOWED_ORIGIN=
# SPEC-020 QR Check-in: signs/verifies every check-in token. REQUIRED — checkinTokens.ts throws
# if unset, breaking check-in, feedback, points redemption, and Mi Pasaporte all at once.
# Generate with `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`.
CHECKIN_SECRET=
# Google Places (New): only used to keep factual fields (address/hours/rating) in sync — never
# a Trust Engine source. Unset disables the Admin "vincular/refrescar Google" actions (503).
GOOGLE_PLACES_API_KEY=
# SPEC-013 "Guardá tu perfil" OTP delivery via Twilio. All three unset (default for local dev)
# falls back to returning the code directly in the response instead of sending a real SMS.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
